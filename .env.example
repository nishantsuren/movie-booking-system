# Copy this file to .env before running docker compose.
# COMPOSE_PROJECT_NAME scopes every container, network, and volume under
# "movieticket_*" so this stack never collides with anything else running
# on your machine, including any other Postgres instance you already have.
COMPOSE_PROJECT_NAME=movieticket

POSTGRES_USER=movieticket
POSTGRES_PASSWORD=movieticket_dev_password
# Host port. Default Postgres is 5432 — this is intentionally different so
# it can run alongside an existing local Postgres on its default port.
POSTGRES_HOST_PORT=5433

# Default Redis is 6379 — offset for the same reason.
REDIS_HOST_PORT=6380

# Toggle referenced throughout the design doc (§3.2). Off for local dev.
AUTH_ENABLED=false
